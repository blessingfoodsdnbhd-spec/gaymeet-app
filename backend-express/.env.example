PORT=3000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/gaymeet?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
CLIENT_URL=http://localhost:3000

# Admin access
# X-Admin-Token machine credential for /api/admin/* (curl, scripts).
ADMIN_TOKEN=
# Comma-separated email allowlist that grants in-app admin (JWT path).
ADMIN_EMAILS=blessingfoodsdnbhd@gmail.com

# Chat auto-translate (country rooms / world lobby). Google Cloud Translation
# API key. Optional — leave blank to disable translation (endpoint 503s, client
# skips it). Console → APIs & Services → Cloud Translation API → Credentials.
GOOGLE_TRANSLATE_API_KEY=
