# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Environment secrets ───────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example committed for reference

# Google Play Developer API service account (used by EAS submit AND
# by the backend's /verify-google-purchase + RTDN routes). Treat as a
# secret — anyone holding it can manage subscriptions on our Play app.
play-service-account.json
**/play-service-account.json
play-service-account*.json
**/play-service-account*.json
# Note: app-rn/google-services.json IS committed on purpose — it's
# bundled into the APK at build time and contains no real secrets
# (just the API key, which is locked down by package+SHA at Google's
# side). Matches the precedent of GoogleService-Info.plist on iOS.

# ── Uploads (ephemeral on Render) ─────────────────────────────────────────────
backend-express/uploads/
backend/uploads/

# ── NestJS build output ───────────────────────────────────────────────────────
backend/dist/

# ── Flutter / Dart ────────────────────────────────────────────────────────────
app/.dart_tool/
app/build/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/pubspec.lock

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

