{
  "expo": {
    "name": "Meyou",
    "slug": "meyou",
    "scheme": "meyou",
    "version": "3.1.18",
    "orientation": "portrait",
    "icon": "./src/assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.meetupnearby.app",
      "supportsTablet": false,
      "buildNumber": "132",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:meyou.uk",
        "applinks:www.meyou.uk"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Meyou uses your location to show you people nearby who share your interests.",
        "NSCameraUsageDescription": "Meyou needs camera access for video calls and profile photos.",
        "NSMicrophoneUsageDescription": "Meyou needs microphone access for voice and video calls.",
        "NSPhotoLibraryUsageDescription": "Meyou needs photo access to upload your moments and profile photos.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.meetupnearby.app",
      "versionCode": 132,
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo.png",
        "backgroundColor": "#FAFAFC"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "meyou.uk",
              "pathPrefix": "/r/"
            },
            {
              "scheme": "https",
              "host": "www.meyou.uk",
              "pathPrefix": "/r/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Meyou uses your location to show you people nearby who share your interests."
        }
      ],
      "expo-asset",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.208538145733-ccuidhniu111ssc70ri9kjrdv6095obs"
        }
      ],
      [
        "react-native-iap",
        {
          "paymentProvider": "Play Store"
        }
      ],
      "./plugins/withIapAndroidXFix.js",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./plugins/withFirebaseMessagingManifestFix.js",
      "./plugins/withCustomNotificationSound.js",
      "@react-native-community/datetimepicker",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "pink",
            "ios": "./src/assets/icons/icon-pink.png",
            "android": {
              "foregroundImage": "./src/assets/icons/icon-pink.png",
              "backgroundColor": "#FAFAFC"
            }
          },
          {
            "name": "purple",
            "ios": "./src/assets/icons/icon-purple.png",
            "android": {
              "foregroundImage": "./src/assets/icons/icon-purple.png",
              "backgroundColor": "#FAFAFC"
            }
          },
          {
            "name": "blue",
            "ios": "./src/assets/icons/icon-blue.png",
            "android": {
              "foregroundImage": "./src/assets/icons/icon-blue.png",
              "backgroundColor": "#FAFAFC"
            }
          },
          {
            "name": "sunset",
            "ios": "./src/assets/icons/icon-sunset.png",
            "android": {
              "foregroundImage": "./src/assets/icons/icon-sunset.png",
              "backgroundColor": "#FAFAFC"
            }
          },
          {
            "name": "night",
            "ios": "./src/assets/icons/icon-night.png",
            "android": {
              "foregroundImage": "./src/assets/icons/icon-night.png",
              "backgroundColor": "#16151F"
            }
          }
        ]
      ],
      "expo-localization"
    ],
    "extra": {
      "apiUrl": "https://gaymeet-api.onrender.com",
      "googleWebClientId": "208538145733-r5ib29ovl992losq4hvpu4rt6lniv22a.apps.googleusercontent.com",
      "googleIosClientId": "208538145733-ccuidhniu111ssc70ri9kjrdv6095obs.apps.googleusercontent.com",
      "eas": {
        "projectId": "6164b27d-200d-4850-a17f-d97b2575027b"
      }
    },
    "owner": "xiuyi"
  }
}
